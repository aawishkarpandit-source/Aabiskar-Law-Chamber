-- stats
DROP POLICY IF EXISTS "Allow authenticated update" ON stats;
DROP POLICY IF EXISTS "Allow authenticated insert" ON stats;
DROP POLICY IF EXISTS "Allow authenticated delete" ON stats;
CREATE POLICY "Allow anon full access" ON stats FOR ALL TO anon USING (true) WITH CHECK (true);

-- practice_areas
DROP POLICY IF EXISTS "Allow authenticated update" ON practice_areas;
DROP POLICY IF EXISTS "Allow authenticated insert" ON practice_areas;
DROP POLICY IF EXISTS "Allow authenticated delete" ON practice_areas;
CREATE POLICY "Allow anon full access" ON practice_areas FOR ALL TO anon USING (true) WITH CHECK (true);

-- team_members
DROP POLICY IF EXISTS "Allow authenticated update" ON team_members;
DROP POLICY IF EXISTS "Allow authenticated insert" ON team_members;
DROP POLICY IF EXISTS "Allow authenticated delete" ON team_members;
CREATE POLICY "Allow anon full access" ON team_members FOR ALL TO anon USING (true) WITH CHECK (true);

-- testimonials
DROP POLICY IF EXISTS "Allow authenticated update" ON testimonials;
DROP POLICY IF EXISTS "Allow authenticated insert" ON testimonials;
DROP POLICY IF EXISTS "Allow authenticated delete" ON testimonials;
CREATE POLICY "Allow anon full access" ON testimonials FOR ALL TO anon USING (true) WITH CHECK (true);

-- site_config
DROP POLICY IF EXISTS "Allow authenticated update" ON site_config;
CREATE POLICY "Allow anon full access" ON site_config FOR ALL TO anon USING (true) WITH CHECK (true);

-- contact_submissions (needed for main site contact form too)
DROP POLICY IF EXISTS "Allow authenticated update" ON contact_submissions;
DROP POLICY IF EXISTS "Allow authenticated delete" ON contact_submissions;
CREATE POLICY "Allow anon insert" ON contact_submissions FOR INSERT TO anon WITH CHECK (true);
CREATE POLICY "Allow anon delete" ON contact_submissions FOR DELETE TO anon USING (true);
CREATE POLICY "Allow anon select" ON contact_submissions FOR SELECT TO anon USING (true);
```

